to read path
    give std_io_read(path)

to write path, content
    std_io_write(path, content)

to append path, content
    std_io_append(path, content)

to exists path
    give std_io_exists(path)

to delete path
    std_io_delete(path)

to copy src, dest
    std_io_copy(src, dest)

to rename old, new
    std_io_rename(old, new)

to mkdir path
    std_io_mkdir(path)

to listdir path
    give std_io_listdir(path)
