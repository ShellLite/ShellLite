to pow base, exp
    result = 1
    for i in range 0 exp
        result = base*result
    give result

to factorial n
    if n <= 1
        give 1
    give n*factorial(n-1)

to sqrt n
    if n < 0
        give 0
    x = n/2.0
    tolerance = 0.00001
    for i in range 0 100
        root_sqrt = x*x
        diff = root_sqrt-n
        if diff < 0
            diff = 0-diff
        if diff < tolerance
            give x
        x = 0.5*(x+(n/x))
    give x  

to is_even n
    if (n%2) == 0
        give true
    else
        give false

to is_odd n
    if (n%2) != 0
        give true
    else 
        give false

#
#   TestCases
#

say pow(2,2) #expected result = 4
say pow(0, 10) #expected result = 0
negative_base = 0-2
say pow(negative_base, 2) #expected result = 4
say pow(negative_base, 3) #expected result = -8

say factorial(3) #expected result = 6
say factorial(2) #expected result = 2

say is_even(2) #expected result = true
say is_even(3) #expected result = false

say is_odd(2) #expected result = false
say is_odd(3) #expected result = true
